# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must never be committed.

# Azure AD tenant ID (differs between NL and international)
VITE_TENANT_ID=

# App registration client ID in Entra ID
VITE_CLIENT_ID=

# Backend API base URL.
# Prototype: paste the Google Apps Script /exec URL here.
# Production: Azure Function base URL.
VITE_API_BASE_URL=https://script.google.com/macros/s/AKfycbwvCAcfRYwV_1JvUQr3WMiAzrHabZ9LYbdsI9tvh54xw-cUjGZEXZx18YmDViVIRA96/exec
